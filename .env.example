NGINX_CAC_PORT=443
NGINX_CAC_HTTP_PORT=8080
POST_AUTH_REDIRECT_URI=/auth/success
POST_AUTH_PROXY_UPSTREAM=http://app:3000/

# Client certificate handling:
# - true (default): require CAC / mTLS
# - false: allow non-mTLS connections (Menlo/SSL inspection proxies won't forward client certs)
REQUIRE_CLIENT_CERT=true

# RECHECK_CAC behavior (only used when RECHECK_CAC=true):
# Defaults close the connection after every response to force a new TLS handshake.
# If assets are failing through the proxy, try:
# RECHECK_CAC_KEEPALIVE_TIMEOUT=65s
# RECHECK_CAC_KEEPALIVE_REQUESTS=1000

# Proxy compatibility (optional):
# Some SSL inspection proxies break HTTP/2 and/or compressed JS/CSS assets.
ENABLE_HTTP2=true
# Example to force upstream to return uncompressed responses:
# UPSTREAM_ACCEPT_ENCODING=identity

# Optional: enable Let's Encrypt via the `certbot` service.
LE_DOMAIN=example.com
LE_EMAIL=admin@example.com
